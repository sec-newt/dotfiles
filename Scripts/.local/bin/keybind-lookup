#!/bin/bash
# Hyprland Keybinding Lookup — live parser
# Reads descriptions directly from 40-binds.conf so it's always in sync.
# Convention: every bind line that should appear here ends with  # Description

CONF="$HOME/.config/hypr/conf.d/40-binds.conf"
FUZZEL_CONFIG="$HOME/.config/fuzzel/fuzzel-keybinds.ini"

# ---------------------------------------------------------------------------
# Convert a raw Hyprland modifier string to "Super+Shift+..." notation
# ---------------------------------------------------------------------------
format_mods() {
    local mods="$1"
    mods="${mods//\$mainMod/Super}"
    mods="${mods//SHIFT/Shift}"
    mods="${mods//CTRL/Ctrl}"
    mods="${mods//ALT/Alt}"
    # Trim, collapse spaces, join with +
    echo "$mods" | xargs | tr ' ' '+'
}

# ---------------------------------------------------------------------------
# Convert a raw Hyprland key name to a readable label
# ---------------------------------------------------------------------------
format_key() {
    local key
    key="$(echo "$1" | xargs)"   # trim whitespace
    case "${key,,}" in
        return)          echo "Enter" ;;
        space)           echo "Space" ;;
        backslash)       echo "\\" ;;
        slash)           echo "/" ;;
        tab)             echo "Tab" ;;
        next)            echo "Page Down" ;;
        prior)           echo "Page Up" ;;
        home)            echo "Home" ;;
        end)             echo "End" ;;
        up)              echo "Up" ;;
        down)            echo "Down" ;;
        left)            echo "Left" ;;
        right)           echo "Right" ;;
        print)           echo "PrintScreen" ;;
        mouse_down)      echo "Scroll Down" ;;
        mouse_up)        echo "Scroll Up" ;;
        mouse_left)      echo "Thumb Back" ;;
        mouse_right)     echo "Thumb Forward" ;;
        "mouse:272")     echo "Left Click" ;;
        "mouse:273")     echo "Right Click" ;;
        "mouse:274")     echo "Middle Click" ;;
        "mouse:277")     echo "Thumb Side" ;;
        xf86audioplay)   echo "MediaPlay" ;;
        xf86audionext)   echo "MediaNext" ;;
        xf86audioprev)   echo "MediaPrev" ;;
        xf86audiostop)   echo "MediaStop" ;;
        *)               echo "$key" ;;
    esac
}

# ---------------------------------------------------------------------------
# Parse the config and build "Combo | Description" lines
# ---------------------------------------------------------------------------
build_entries() {
    while IFS= read -r line; do
        # Must be a bind line with a trailing # description
        [[ "$line" =~ ^bind[mr]?[[:space:]]*=[[:space:]]*(.*)[[:space:]]#[[:space:]]*(.+)$ ]] || continue

        lhs="${BASH_REMATCH[1]}"
        desc="${BASH_REMATCH[2]}"

        # Split lhs on commas: field 1 = modifiers, field 2 = key
        IFS=',' read -r raw_mods raw_key _rest <<< "$lhs"

        mods="$(format_mods "$raw_mods")"
        key="$(format_key "$raw_key")"

        if [[ -z "$mods" ]]; then
            combo="$key"
        else
            combo="${mods}+${key}"
        fi

        printf '%s | %s\n' "$combo" "$desc"
    done < "$CONF"
}

# ---------------------------------------------------------------------------
# Show in fuzzel and act on selection
# ---------------------------------------------------------------------------
ENTRIES="$(build_entries)"

if [[ -z "$ENTRIES" ]]; then
    hyprctl notify 1 4000 "rgb(ff4444)" "keybind-lookup: no entries found — check $CONF"
    exit 1
fi

if [[ -f "$FUZZEL_CONFIG" ]]; then
    SELECTION=$(echo "$ENTRIES" | fuzzel --dmenu --config="$FUZZEL_CONFIG")
else
    SELECTION=$(echo "$ENTRIES" | fuzzel --dmenu)
fi

if [[ -n "$SELECTION" ]]; then
    KEYBIND=$(echo "$SELECTION" | cut -d'|' -f1 | xargs)
    DESC=$(echo "$SELECTION" | cut -d'|' -f2 | xargs)
    hyprctl notify 1 8000 "rgb(00ccff)" "$KEYBIND: $DESC"
    echo "$KEYBIND" | wl-copy
fi
