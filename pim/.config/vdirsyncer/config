[general]
status_path = "~/.local/share/vdirsyncer/status/"

# Calendars
[pair calendars]
a = "calendars_local"
b = "calendars_remote"
collections = ["from a", "from b"]
metadata = ["displayname", "color"]
conflict_resolution = "b wins"

# Contacts
[pair contacts]
a = "contacts_local"
b = "contacts_remote"
collections = [["contacts2026", "contacts2026", "contacts2026"]]
metadata = ["displayname"]

[storage calendars_local]
type = "filesystem"
path = "~/.local/share/calendars/"
fileext = ".ics"

[storage calendars_remote]
type = "caldav"
url = "http://zeus:5232/newt/"
username = "newt"
password = "changeme"

[storage contacts_local]
type = "filesystem"
path = "~/.local/share/contacts/"
fileext = ".vcf"

[storage contacts_remote]
type = "carddav"
url = "http://zeus:5232/newt/"
username = "newt"
password = "changeme"
