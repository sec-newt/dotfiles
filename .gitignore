# Local machine secrets — never commit
home/.config/secrets/

# OpenClaw gateway service — auto-generated by `openclaw gateway install`
# Contains OPENCLAW_GATEWAY_TOKEN inline; never commit
systemd/.config/systemd/user/openclaw-gateway.service
systemd/.config/systemd/user/openclaw-gateway.service.bak
systemd/.config/systemd/user/default.target.wants/openclaw-gateway.service

# Editor
*.swp
.swp
